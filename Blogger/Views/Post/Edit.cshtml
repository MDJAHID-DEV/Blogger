@model Post
<partial name="../Shared/Common/_PageHeader.cshtml" model='("Edit Blog", "Blogs", "/Post/List", $"Edit")' />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">

                <h2 class="card-title">Edit your blog</h2>

                <form asp-action="Edit" method="post">
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="mb-3">
                                <label asp-for="Title"></label>
                                <input asp-for="Title" class="form-control">
                            </div>
                        </div>
                        <div class="col-sm-12">
                            <div class="mb-3">
                                <label asp-for="Slug"></label>
                                <input asp-for="Slug" class="form-control">
                            </div>
                        </div>
                        <div class="col-sm-12">
                            <div class="mb-3">
                                <label asp-for="Content"></label>
                                <textarea asp-for="Content" class="form-control" placeholder="Write Your Blog Here....."></textarea>
                            </div>
                        </div>

                        <div class="col-sm-12">
                            <div class="mb-3">
                                <label asp-for="Status"></label>
                                <br />
                                <select class="form-select w-50" asp-for="Status" asp-items="Html.GetEnumSelectList<Status>()" style="padding: 0.47rem 0.75rem;">
                                </select>

                            </div>
                        </div>


                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-primary waves-effect waves-light">Save Changes</button>
                        </div>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

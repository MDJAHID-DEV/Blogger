@model (string pageTitle,string pageBackLinkName, string pageBackLink,string pageName)
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0 font-size-18">@Model.pageTitle</h4>

            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="@Model.pageBackLink">@Model.pageBackLinkName</a></li>
                    <li class="breadcrumb-item active">@Model.pageName</li>
                </ol>
            </div>

        </div>
    </div>
</div>

